# apps/web — required environment variables
# Copy this file to .env.local and fill in your values.
# This app uses a separate Supabase project from admin/docs.
# Get all keys from: https://supabase.com/dashboard → Project Settings → API

# Supabase project reference ID (just the ref, not the full URL)
VITE_SUPABASE_PROJECT_ID=<project-ref>

# Supabase full URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon/publishable key (public — safe to expose to browser)
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>

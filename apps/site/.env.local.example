# apps/site — environment variables
# Copy this file to .env.local and fill in your values.

# ──────────────────────────────────────────────
# Supabase [REQUIRED]
# Get all keys from: https://supabase.com/dashboard → Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ──────────────────────────────────────────────
# Email — Resend [OPTIONAL]
# Used by the contact/waitlist API route to send transactional email.
# Get your API key from: https://resend.com/api-keys
# ──────────────────────────────────────────────
RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Celune <hello@celune.ai>   # defaults to Celune <hello@celune.ai>

# ──────────────────────────────────────────────
# Analytics — PostHog [OPTIONAL]
# Get your project API key from: https://us.posthog.com → Project Settings → Project API Key
# ──────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # defaults to US cloud

# ──────────────────────────────────────────────
# Branding overrides [OPTIONAL]
# These have sensible defaults — only set if you need to override.
# ──────────────────────────────────────────────
# NEXT_PUBLIC_APP_DOMAIN=app.celune.ai
# NEXT_PUBLIC_MARKETING_DOMAIN=celune.ai
# NEXT_PUBLIC_DOCS_DOMAIN=docs.celune.ai
# NEXT_PUBLIC_SUPPORT_EMAIL=hello@celune.ai

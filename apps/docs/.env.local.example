# apps/docs — required environment variables
# Copy this file to .env.local and fill in your values.
# Get all keys from: https://supabase.com/dashboard → Project Settings → API

# Supabase (public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Note: docs is a static MDX renderer — no server-side DB calls, no service role key needed.

# Next.js base path (set to /docs for docs app)
NEXT_PUBLIC_BASE_PATH=/docs

# Sentry — error tracking
# DSN from: https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>

# Sentry — source map uploads (only needed in CI)
SENTRY_AUTH_TOKEN=sntrys_...

# apps/docs — environment variables
# Copy this file to .env.local and fill in your values.

# ──────────────────────────────────────────────
# Supabase [REQUIRED]
# Used in API-reference code examples. Public keys only — no service role key needed.
# Get keys from: https://supabase.com/dashboard → Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ──────────────────────────────────────────────
# Sentry — error tracking [OPTIONAL]
# DSN from: https://sentry.io → Settings → Projects → Client Keys (DSN)
# ──────────────────────────────────────────────
SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.us.sentry.io/<project-id>

# ──────────────────────────────────────────────
# Sentry — source map uploads [OPTIONAL]
# Only needed in CI / Vercel builds. Without this, Sentry is skipped at build time.
# Get token from: https://sentry.io → Settings → Auth Tokens
# ──────────────────────────────────────────────
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=smejkal-design          # defaults to smejkal-design

{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "sync-vault": "node scripts/sync-vault.mjs",
    "lint-docs": "node scripts/lint-docs.mjs",
    "lint-docs:fix": "node scripts/lint-docs.mjs --fix",
    "dev": "node scripts/sync-vault.mjs && node scripts/lint-docs.mjs && next dev --port 3004 --webpack",
    "build": "node scripts/sync-vault.mjs && node scripts/lint-docs.mjs && next build --webpack",
    "start": "next start --port 3004",
    "lint": "eslint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@repo/ui": "workspace:*",
    "@sentry/nextjs": "^10.40.0",
    "@shikijs/rehype": "^3.23.0",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
